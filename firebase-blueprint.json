{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product." },
        "price": { "type": "number", "description": "The price of the product." },
        "discountPrice": { "type": "number", "description": "The discounted price of the product." },
        "image": { "type": "string", "description": "The image URL of the product." },
        "brand": { "type": "string", "description": "The brand of the product." },
        "category": { "type": "string", "description": "The category of the product." },
        "shortSpecs": { "type": "string", "description": "Short specifications of the product." },
        "fullSpecs": { "type": "string", "description": "Full specifications of the product." },
        "stockStatus": { "type": "string", "enum": ["In Stock", "Out of Stock"], "description": "The stock status of the product." },
        "createdAt": { "type": "number", "description": "The creation timestamp of the product." }
      },
      "required": ["name", "price", "image", "brand", "category", "shortSpecs", "fullSpecs", "stockStatus", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who placed the order." },
        "userEmail": { "type": "string", "description": "The email of the user who placed the order." },
        "customerName": { "type": "string", "description": "The name of the customer." },
        "phone": { "type": "string", "description": "The phone number of the customer." },
        "address": { "type": "string", "description": "The address of the customer." },
        "paymentMethod": { "type": "string", "description": "The payment method used." },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalPrice": { "type": "number", "description": "The total price of the order." },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Shipped", "Delivered", "Cancelled"], "description": "The status of the order." },
        "createdAt": { "type": "number", "description": "The creation timestamp of the order." }
      },
      "required": ["userId", "customerName", "phone", "address", "paymentMethod", "items", "totalPrice", "status", "createdAt"]
    },
    "Banner": {
      "title": "Banner",
      "description": "A banner image displayed on the home page.",
      "type": "object",
      "properties": {
        "image": { "type": "string", "description": "The image URL of the banner." },
        "title": { "type": "string", "description": "The title of the banner." },
        "subtitle": { "type": "string", "description": "The subtitle of the banner." },
        "createdAt": { "type": "number", "description": "The creation timestamp of the banner." }
      },
      "required": ["image", "title", "subtitle", "createdAt"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Collection of products." },
    "orders": { "schema": "Order", "description": "Collection of orders." },
    "banners": { "schema": "Banner", "description": "Collection of banner images." }
  }
}
